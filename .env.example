# Copy to .env and fill in. .env is git-ignored.

# --- Tesla Powerwall 3 (local Gateway, TEDAPI) ---
# IP of the Powerwall Gateway on your LAN (find via Google Home app or router).
POWERWALL_HOST=192.168.1.XXX
# "Customer" login password, printed on the Gateway's QR-code sticker.
POWERWALL_PASSWORD=
# Gateway serial number (last 5 of SN often required for TEDAPI).
POWERWALL_GW_SERIAL=

# --- Emporia (cloud) ---
EMPORIA_USERNAME=
EMPORIA_PASSWORD=
# Device GID of the EV Charger Classic, filled in after first probe.
EMPORIA_EVSE_GID=

# --- Control loop ---
# Seconds between decisions when running `elec-auto run`.
POLL_INTERVAL_SEC=30
# Safety floor for Powerwall state-of-charge (%) before EV is allowed to pull.
BATTERY_RESERVE_PCT=80
# Min EV charge current (A). Emporia allows 6 A minimum on most hardware.
EV_MIN_AMPS=6
# Max EV charge current (A). Set to your circuit's ampacity.
EV_MAX_AMPS=40
# Service voltage (V) used to convert watts to amps. 240 for typical US L2.
EV_VOLTAGE=240
