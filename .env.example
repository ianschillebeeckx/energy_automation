# Copy to .env and fill in. .env is git-ignored.
#
# Only the settings most deployers tune are listed here. The full surface
# (battery vampire draw, panel geometry, NWS user-agent, etc.) lives in
# src/elec_auto/config.py — override any of them by adding the SHOUTY_CASE
# name to this file.

# --- Tesla Powerwall 3 ---
# "cloud" (Tesla Owner API, OAuth) or "local" (TEDAPI on the Gateway).
POWERWALL_MODE=cloud

# Cloud mode (recommended until we have the Gateway password).
TESLA_EMAIL=
# Only set if your Tesla account has multiple energy sites.
TESLA_SITE_ID=

# Local mode (TEDAPI). Gateway password is on the PW3 sticker (inside cover).
POWERWALL_HOST=192.168.86.169
POWERWALL_GW_PASSWORD=
POWERWALL_GW_SERIAL=STG1252810022MM

# --- Emporia (cloud) ---
EMPORIA_USERNAME=
EMPORIA_PASSWORD=
# Device GID of the EV Charger Classic. Leave blank on first run; `probe`
# will list all chargers so you can find the right one.
EMPORIA_EVSE_GID=

# --- Control loop ---
POLL_INTERVAL_SEC=30
# Powerwall SoC floor (%) below which EV is not allowed to pull on Surplus.
BATTERY_RESERVE_PCT=80
EV_MIN_AMPS=6
EV_MAX_AMPS=40
EV_VOLTAGE=240

# Per-action enable flags. Mirrored on the dashboard as toggles.
SURPLUS_ENABLED=true
MORNING_DUMP_ENABLED=true

# --- Morning dump window ---
# Drains the battery to free headroom for the day's PV.
MORNING_DUMP_START_HOUR=5
MORNING_DUMP_START_MINUTE=0
MORNING_DUMP_END_HOUR=8
MORNING_DUMP_END_MINUTE=0
MORNING_DUMP_FLOOR_PCT=10
# Deeper floor on forecast-sunny days (PV above the kWh threshold).
MORNING_DUMP_SUNNY_THRESHOLD_KWH=30
MORNING_DUMP_SUNNY_FLOOR_PCT=5
# Cap on dump amperage. 29 A (~7 kW) leaves PW3 inverter room for HVAC.
MORNING_DUMP_MAX_AMPS=29

# --- Site geometry (for clear-sky PV model + sunset auto-flip) ---
LATITUDE=
LONGITUDE=
# Solar array: azimuth 0=N, 90=E, 180=S, 270=W. Tilt is degrees from horizontal.
SOLAR_ARRAY_MAX_KW=6.6
SOLAR_PANEL_AZIMUTH_DEG=180
SOLAR_PANEL_TILT_DEG=30
SOLAR_SYSTEM_LOSS_FACTOR=0.09

# --- Solcast (hobbyist tier, 10 calls/day per resource) ---
# Sign up at solcast.com, create a rooftop site, then copy the API key + ID.
SOLCAST_API_KEY=
SOLCAST_RESOURCE_ID=

# --- NWS (US National Weather Service) ---
# Free, no API key. Default station is KSFO; override for your site.
NWS_OBS_STATION_ID=KSFO

# Timezone used for Tesla data timestamps and morning-dump scheduling.
TIMEZONE=America/Los_Angeles
