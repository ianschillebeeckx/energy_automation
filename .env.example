# Copy to .env and fill in. .env is git-ignored.

# --- Tesla Powerwall 3 ---
# "cloud" (Tesla Owner API, OAuth) or "local" (TEDAPI on the Gateway).
POWERWALL_MODE=cloud

# Cloud mode (recommended until we have the Gateway password).
TESLA_EMAIL=
# Only set if your Tesla account has multiple energy sites.
TESLA_SITE_ID=

# Local mode (TEDAPI). Gateway password is on the PW3 sticker (inside cover).
POWERWALL_HOST=192.168.86.169
POWERWALL_GW_PASSWORD=
POWERWALL_GW_SERIAL=STG1252810022MM

# --- Emporia (cloud) ---
EMPORIA_USERNAME=
EMPORIA_PASSWORD=
# Device GID of the EV Charger Classic. Leave blank on first run; `probe`
# will list all chargers so you can find the right one.
EMPORIA_EVSE_GID=

# --- Control loop ---
POLL_INTERVAL_SEC=30
# Powerwall SoC floor (%) below which EV is not allowed to pull.
BATTERY_RESERVE_PCT=80
EV_MIN_AMPS=6
EV_MAX_AMPS=40
EV_VOLTAGE=240

# Timezone used for Tesla data timestamps.
TIMEZONE=America/Los_Angeles
